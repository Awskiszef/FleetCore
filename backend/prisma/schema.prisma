generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MECHANIC
  RECEPTIONIST
}

enum RepairOrderStatus {
  NEW
  WAITING
  DIAGNOSING
  REPAIRING
  READY
  COMPLETED
  DELIVERED
  CANCELLED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  fullName     String
  role         Role      @default(MECHANIC)
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  repairOrders RepairOrder[] @relation("MechanicOrders")
  inventoryTransactions InventoryTransaction[]
  orderHistories RepairOrderHistory[]
  intakesCreated VehicleIntake[]
  estimatesCreated Estimate[]
}

model Customer {
  id           String        @id @default(uuid())
  fullName     String
  companyName  String?
  phone        String?
  email        String?
  address      String?
  nip          String?       @unique
  notes        String?
  vehicles     Vehicle[]
  repairOrders RepairOrder[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([phone])
  @@index([email])
}

model Vehicle {
  id               String        @id @default(uuid())
  customerId       String
  customer         Customer      @relation(fields: [customerId], references: [id])
  vin              String?
  licensePlate     String?
  make             String?
  model            String?
  generation       String?
  productionYear   Int?
  engine           String?
  engineCode       String?
  horsepower       Int?
  fuelType         String?
  transmission     String?
  driveType        String?
  bodyType         String?
  color            String?
  mileage          Int?
  registrationDate DateTime?
  notes            String?
  repairOrders     RepairOrder[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  @@index([vin])
  @@index([licensePlate])
}

model RepairOrder {
  id                 String            @id @default(uuid())
  customerId         String
  customer           Customer          @relation(fields: [customerId], references: [id])
  vehicleId          String
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [id])
  assignedMechanicId String?
  assignedMechanic   User?             @relation("MechanicOrders", fields: [assignedMechanicId], references: [id])
  status             RepairOrderStatus @default(NEW)
  reportedIssue      String
  diagnosis          String?
  mechanicNotes      String?
  estimatedCost      Decimal?          @db.Decimal(10, 2)
  finalCost          Decimal?          @db.Decimal(10, 2)
  laborCost          Decimal?          @db.Decimal(10, 2)
  marginPercentage   Decimal?          @db.Decimal(5, 2)
  parts              RepairOrderPart[]
  history            RepairOrderHistory[]
  inventoryTransactions InventoryTransaction[]
  invoiceId          String?
  invoiceUrl         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  completedAt        DateTime?
  deletedAt          DateTime?

  intakeProtocol     VehicleIntake?
  estimates          Estimate[]

  @@index([status])
}

model RepairOrderPart {
  id              String       @id @default(uuid())
  repairOrderId   String
  repairOrder     RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  partId          String
  part            Part         @relation(fields: [partId], references: [id])
  quantity        Int          @default(1)
  priceAtUsage    Decimal      @db.Decimal(10, 2)
  createdAt       DateTime     @default(now())

  @@unique([repairOrderId, partId])
}

model Part {
  id                String   @id @default(uuid())
  name              String
  oemNumber         String?
  aftermarketNumber String?
  manufacturer      String?
  supplierId        String?
  supplier          Supplier? @relation(fields: [supplierId], references: [id])
  unitPrice         Decimal   @db.Decimal(10, 2)
  quantity          Int       @default(0)
  reservedQuantity  Int       @default(0)
  barcode           String?   @unique
  shelfLocation     String?
  minQuantity       Int       @default(0)
  repairOrders      RepairOrderPart[]
  inventoryTransactions InventoryTransaction[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([oemNumber])
  @@index([aftermarketNumber])
}

model Attachment {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  fileName   String
  mimeType   String
  url        String
  size       Int
  createdAt  DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

enum FleetLogType {
  REFUEL
  SERVICE
  PARTS
  INSURANCE
  OTHER
}

model FleetVehicle {
  id           String   @id @default(uuid())
  name         String
  licensePlate String?
  vin          String?
  make         String?
  model        String?
  productionYear Int?
  logs         FleetVehicleLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
}

model FleetVehicleLog {
  id             String       @id @default(uuid())
  fleetVehicleId String
  fleetVehicle   FleetVehicle @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)
  date           DateTime     @default(now())
  type           FleetLogType
  mileage        Int?
  cost           Decimal?     @db.Decimal(10, 2)
  liters         Decimal?     @db.Decimal(10, 2)
  title          String
  location       String?
  policyNumber   String?
  provider       String?
  notes          String?
  createdAt      DateTime     @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

enum InventoryTransactionType {
  IN
  OUT
  RESERVE
  UNRESERVE
}

model InventoryTransaction {
  id            String   @id @default(uuid())
  partId        String
  part          Part     @relation(fields: [partId], references: [id])
  type          InventoryTransactionType
  quantity      Int
  repairOrderId String?
  repairOrder   RepairOrder? @relation(fields: [repairOrderId], references: [id])
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  notes         String?
  createdAt     DateTime @default(now())

  @@index([partId])
  @@index([repairOrderId])
}

model RepairOrderHistory {
  id            String   @id @default(uuid())
  repairOrderId String
  repairOrder   RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  status        RepairOrderStatus
  notes         String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())

  @@index([repairOrderId])
}

model Supplier {
  id          String   @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  nip         String?  @unique
  notes       String?
  parts       Part[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model VehicleIntake {
  id              String   @id @default(uuid())
  repairOrderId   String   @unique
  repairOrder     RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  mileage         Int?
  fuelLevel       Int?     // 0-100 percentage
  damages         String?
  equipment       String?
  signatureUrl    String?
  createdByUserId String?
  createdByUser   User?    @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum EstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Estimate {
  id              String         @id @default(uuid())
  repairOrderId   String
  repairOrder     RepairOrder    @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  status          EstimateStatus @default(DRAFT)
  validUntil      DateTime?
  notes           String?
  totalNet        Decimal        @db.Decimal(10, 2) @default(0)
  totalGross      Decimal        @db.Decimal(10, 2) @default(0)
  pdfUrl          String?
  items           EstimateItem[]
  createdByUserId String?
  createdByUser   User?          @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
}

enum EstimateItemType {
  PART
  LABOR
}

model EstimateItem {
  id         String           @id @default(uuid())
  estimateId String
  estimate   Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  type       EstimateItemType
  name       String
  quantity   Int              @default(1)
  unitPrice  Decimal          @db.Decimal(10, 2)
  taxRate    Decimal          @db.Decimal(5, 2) @default(23.00)
  totalNet   Decimal          @db.Decimal(10, 2)
  totalGross Decimal          @db.Decimal(10, 2)
  createdAt  DateTime         @default(now())
}

